0098                  00391 SCAN_KEYPAD:
                      00392     ; Clear flags
0098   102A           00393     BCF     NEW_KEY_FLAG, 0
0099   01A6           00394     CLRF    KEY_ROW
009A   01A7           00395     CLRF    KEY_COL
009B   01A8           00396     CLRF    KEY_INDEX

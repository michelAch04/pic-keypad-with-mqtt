00A0   0088           00408     MOVWF   PORTD               ; All columns HIGH
                      00409     
                      00410     ; Calculate bit mask for current column (active LOW)
                      00411     ; Col 0 = RD7 (MSB), Col 7 = RD0 (LSB)
00A1   082E           00412     MOVF    SCAN_COL, W
00A2   2???           00413     CALL    GET_COL_MASK        ; Get inverted mask
00A3   0088           00414     MOVWF   PORTD               ; Apply to columns
                      00415     
                      00416     ; Small delay for signal settling
00A4   0000           00417     NOP
00A5   0000           00418     NOP
00A6   0000           00419     NOP
00A7   0000           00420     NOP
                      00421     
                      00422     ; Read rows - Row 0 = RB7, Row 3 = RB4 (inverted physical mapping)
00A8   0806           00423     MOVF    PORTB, W
00A9   39F0           00424     ANDLW   B'11110000'         ; Mask rows
                      00425     
                      00426     ; Check Row 0 (RB7 - Q W E R T Y U I row)
00AA   1E06           00427     BTFSS   PORTB, 4
00AB   2???           00428     GOTO    FOUND_ROW0
                      00429     
                      00430     ; Check Row 1 (RB6 - A S D F G H J K row)
00AC   1E86           00431     BTFSS   PORTB, 5
00AD   2???           00432     GOTO    FOUND_ROW1
                      00433     
                      00434     ; Check Row 2 (RB5 - Z X C V B N M L row)
00AE   1F06           00435     BTFSS   PORTB, 6
00AF   2???           00436     GOTO    FOUND_ROW2
                      00437     
                      00438     ; Check Row 3 (RB4 - SHIFT O P / * + - SHIFT row)
00B0   1F86           00439     BTFSS   PORTB, 7
00B1   2???           00440     GOTO    FOUND_ROW3
                      00441     
                      00442     ; No key in this column, try next
00B2   0AAE           00443     INCF    SCAN_COL, F
00B3   082E           00444     MOVF    SCAN_COL, W
00B4   3A08           00445     XORLW   D'8'
00B5   1D03           00446     BTFSS   STATUS, Z
00B6   2???           00447     GOTO    SCAN_NEXT_COL
                      00448     
                      00449     ; No key found
00B7   2???           00450     GOTO    SCAN_DONE
                      00451 
00B8                  00452 FOUND_ROW0:
00B8   01A6           00453     CLRF    KEY_ROW             ; Row 0
00B9   2???           00454     GOTO    CALC_INDEX
                      00455     
00BA                  00456 FOUND_ROW1:

017A                  00814 DO_CALC_OFFSET:
                      00815     ; --- Step 2: Calculate 16-bit Offset = (Char - 42) * 5 ---
                      00816     
                      00817     ; A. Subtract Base (42)
017A   302A           00818     MOVLW   D'42'
017B   022F           00819     SUBWF   TEMP_VAR, W         ; W = Char - 42

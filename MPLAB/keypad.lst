                      00302 
                      00303 ;===============================================================================
                      00304 ; INTERRUPT SERVICE ROUTINE
                      00305 ;===============================================================================
006E                  00306 ISR:
                      00307     ; --- Context Saving ---
006E   00A0           00308     MOVWF   W_TEMP
006F   0E03           00309     SWAPF   STATUS, W
0070   00A1           00310     MOVWF   STATUS_TEMP
0071   080A           00311     MOVF    PCLATH, W
0072   00A2           00312     MOVWF   PCLATH_TEMP
                      00313     
                      00314     ; --- CRITICAL FIX: Reset PCLATH for ISR Code ---
0073   018A           00315     CLRF    PCLATH          ; Assuming ISR code is in Page 0
                      00316     
                      00317     ; --- Interrupt Logic ---
0074   1C0B           00318     BTFSS   INTCON, RBIF
0075   2???           00319     GOTO    ISR_EXIT
                      00320     
                      00321     ; Debounce delay (20ms)
0076   2???           00322     CALL    DELAY_20MS
                      00323     
                      00324     ; Read PORTB to clear mismatch condition
0077   0806           00325     MOVF    PORTB, W
                      00326     
                      00327     ; Check if any row is LOW (key pressed)
0078   39F0           00328     ANDLW   B'11110000'         ; Mask rows RB4-RB7
0079   3AF0           00329     XORLW   B'11110000'         ; Compare with all HIGH
007A   1903           00330     BTFSC   STATUS, Z
007B   2???           00331     GOTO    ISR_CLEAR_EXIT      ; No key pressed, exit
                      00332     
                      00333     ; Scan keypad to find pressed key
007C   2???           00334     CALL    SCAN_KEYPAD
                      00335     
                      00336     ; Check if new key was found
007D   1C2A           00337     BTFSS   NEW_KEY_FLAG, 0
007E   2???           00338     GOTO    ISR_CLEAR_EXIT
                      00339     
                      00340     ; Check if SHIFT key pressed
007F   0828           00341     MOVF    KEY_INDEX, W
0080   3A18           00342     XORLW   SHIFT_INDEX_L
0081   1903           00343     BTFSC   STATUS, Z
0082   2???           00344     GOTO    ISR_SHIFT_PRESSED

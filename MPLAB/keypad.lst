0083   0828           00346     MOVF    KEY_INDEX, W
0084   3A1F           00347     XORLW   SHIFT_INDEX_R
0085   1903           00348     BTFSC   STATUS, Z
0086   2???           00349     GOTO    ISR_SHIFT_PRESSED
                      00350     
0087   0828           00351         MOVF    KEY_INDEX, W
                      00352 

                      00098     ; Always refresh display first (critical for no flicker)
0014   2???           00099     CALL    DISPLAY_CHAR
                      00100     
                      00101     ; Check if in shift mode
0015   1C29           00102     BTFSS   SHIFT_FLAG, 0
0016   2???           00103     GOTO    IDLE_MODE
                      00104     
                      00105 ;-------------------------------------------------------------------------------
                      00106 ; SHIFT Mode - Poll for shift release and character keys
                      00107 ; FIX: Use dedicated character key scan that ignores row 3 (shift row)
                      00108 ;-------------------------------------------------------------------------------
0017                  00109 SHIFT_MODE:
                      00110     ; Disable Port B interrupts during polling
0017   118B           00111     BCF     INTCON, RBIE
                      00112     
                      00113     ; First check: Is shift key still held?
0018   2???           00114     CALL    CHECK_SHIFT_HELD
0019   1C29           00115     BTFSS   SHIFT_FLAG, 0
001A   2???           00116     GOTO    SHIFT_RELEASED      ; Shift was released
                      00117     
                      00118     ; Scan for CHARACTER keys only (ignores shift row)
001B   2???           00119     CALL    SCAN_CHAR_KEY
                      00120     
                      00121     ; Check if a character key was found
001C   1C2A           00122     BTFSS   NEW_KEY_FLAG, 0
001D   2???           00123     GOTO    CHAR_KEY_RELEASED   ; No char key pressed, check for repeat reset
                      00124     
                      00125     ; Check if this is the SAME key as last time (prevent repeats)
001E   0828           00126     MOVF    KEY_INDEX, W
001F   0634           00127     XORWF   LAST_KEY_INDEX, W
0020   1903           00128     BTFSC   STATUS, Z
0021   2???           00129     GOTO    MAIN_LOOP           ; Same key still held, don't repeat
                      00130     
                      00131     ; NEW character key detected - process it
0022   0828           00132     MOVF    KEY_INDEX, W
0023   00B4           00133     MOVWF   LAST_KEY_INDEX      ; Remember this key
                      00134     
0024   2???           00135     CALL    PROCESS_SHIFTED_KEY
0025   102A           00136     BCF     NEW_KEY_FLAG, 0
0026   2???           00137     GOTO    MAIN_LOOP
                      00138 
0027                  00139 CHAR_KEY_RELEASED:
                      00140     ; No character key pressed - reset last key tracker
0027   30FF           00141     MOVLW   0xFF
0028   00B4           00142     MOVWF   LAST_KEY_INDEX
0029   2???           00143     GOTO    MAIN_LOOP
                      00144     
002A                  00145 SHIFT_RELEASED:
                      00146     ; Shift key released - re-enable interrupts
002A   102A           00147     BCF     NEW_KEY_FLAG, 0
002B   30FF           00148     MOVLW   0xFF
002C   00B4           00149     MOVWF   LAST_KEY_INDEX      ; Reset key tracker
002D   158B           00150     BSF     INTCON, RBIE

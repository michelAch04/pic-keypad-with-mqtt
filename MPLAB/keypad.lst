                      00160 
                      00161 ;-------------------------------------------------------------------------------
                      00162 ; Check if shift key is currently held (checks both shift positions)
                      00163 ; Sets SHIFT_FLAG if either shift is pressed
                      00164 ; Col 0 = RD7, Col 7 = RD0, Row 3 = RB4 (not RB7!)
                      00165 ;-------------------------------------------------------------------------------
0031                  00166 CHECK_SHIFT_HELD:
0031   1029           00167     BCF     SHIFT_FLAG, 0       ; Assume not held
                      00168     
                      00169     ; Check left shift (col 0 = RD0, row 3 = RB7)
0032   30FF           00170     MOVLW   0xFF
0033   0088           00171     MOVWF   PORTD
0034   1008           00172     BCF     PORTD, 0            ; Activate column 0 (RD0 low)
0035   0000           00173     NOP
0036   0000           00174     NOP
0037   1F86           00175     BTFSS   PORTB, 7            ; Check RB7 (row 3)
0038   1429           00176     BSF     SHIFT_FLAG, 0       ; Left shift is held
                      00177     
                      00178     ; Check right shift (col 7 = RD7, row 3 = RB7)
0039   30FF           00179     MOVLW   0xFF
003A   0088           00180     MOVWF   PORTD
003B   1388           00181     BCF     PORTD, 7            ; Activate column 7 (RD7 low)
003C   0000           00182     NOP
003D   0000           00183     NOP
003E   1F86           00184     BTFSS   PORTB, 7            ; Check RB7 (row 3)
003F   1429           00185     BSF     SHIFT_FLAG, 0       ; Right shift is held
                      00186     
                      00187     ; Reset columns
0040   0188           00188     CLRF    PORTD
0041   0008           00189     RETURN
                      00190 
                      00191 ;===============================================================================
                      00192 ; INITIALIZATION SUBROUTINES
                      00193 ;===============================================================================
                      00194 

017D   01B1           00821     CLRF    FONT_OFFSET_H       ; H = 0
                      00822 
                      00823     ; B. Multiply by 4 (Shift Left twice)
                      00824     ; Shift 1 (x2)
017E   1003           00825     BCF     STATUS, C
017F   0DB0           00826     RLF     FONT_OFFSET_L, F
0180   0DB1           00827     RLF     FONT_OFFSET_H, F    ; Carry rotates into High Byte
                      00828     ; Shift 2 (x4)
0181   1003           00829     BCF     STATUS, C
0182   0DB0           00830     RLF     FONT_OFFSET_L, F
